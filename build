#!/usr/bin/env bash
set -e
trap 'echo "Error on line $LINENO. Setup failed." >&2' ERR

if ! command -v pkg &>/dev/null; then
  echo "Error: This installer requires Termux (pkg package manager)." >&2
  exit 1
fi

cd "$HOME"

echo "Updating package list and installing required packages..."
pkg update -y
pkg install -y clang git ripgrep gh fzf python nodejs neovim

for cmd in git nvim; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd not found after installation. Aborting." >&2
    exit 1
  fi
done

REPO_URL="${REPO_URL:-https://github.com/nurmuhammedjoy/zenvim.git}"
REPO_DIR="zenvim"

if [ -d "$REPO_DIR" ]; then
  echo "Removing existing $REPO_DIR directory..."
  rm -rf "$REPO_DIR"
fi

echo "Cloning $REPO_URL..."
git clone "$REPO_URL"

NVIM_CONFIG_SRC="$REPO_DIR/config"
NVIM_CONFIG_DEST="$HOME/.config/nvim"

if [ -d "$NVIM_CONFIG_DEST" ]; then
  echo "Backing up existing Neovim config to ${NVIM_CONFIG_DEST}.bak..."
  mv "$NVIM_CONFIG_DEST" "${NVIM_CONFIG_DEST}.bak"
fi

echo "Creating Neovim config directory..."
mkdir -p "$NVIM_CONFIG_DEST"

if [ -d "$NVIM_CONFIG_SRC" ] && [ "$(ls -A "$NVIM_CONFIG_SRC")" ]; then
  echo "Copying Neovim config files..."
  cp -r "$NVIM_CONFIG_SRC"/* "$NVIM_CONFIG_DEST"/
else
  echo "Warning: No config files found in $NVIM_CONFIG_SRC."
fi

echo "Cleaning up cloned repository..."
rm -rf "$REPO_DIR"

echo "Setup complete. Run 'nvim' to start Neovim."
